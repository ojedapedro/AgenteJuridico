# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Agente Juridico Database Configuration (PostgreSQL / Supabase)
# Note: If no DATABASE_URL or DB_HOST is provided, the system falls back to a local JSON Mock DB for development.

# Option 1: Connection string (Recommended for Supabase)
# DATABASE_URL=postgresql://postgres.[YOUR_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Option 2: Individual parameters
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSL=true

# Security Configuration (AES-256 and JWT)
ENCRYPTION_KEY="default_development_key_32_bytes_long"
JWT_SECRET="super_secret_jwt_key_for_legal_library"
DOWNLOAD_SECRET="download_token_secret_key_987654"
